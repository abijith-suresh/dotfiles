# OS junk
.DS_Store
Thumbs.db

# Compiled zsh files
*.zwc
*.zwc.old

# Runtime / cache files inside tracked config trees
configs/nvim/.config/nvim/lazy-lock.json
configs/tmux/.config/tmux/plugins/
configs/zsh/.config/zsh/.zsh_history
configs/zsh/.config/zsh/.zcompdump*

# Explicit local override files
configs/zsh/.config/zsh/*.local
configs/bash/*.local
configs/git/.config/git/*.local

# Dotfiles-managed backups created during migrations/tests
*.backup
*.backup.*
