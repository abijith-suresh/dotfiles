# Compiled zsh files
*.zwc
*.zwc.old

# Neovim plugin lockfile (regenerated on install)
configs/nvim/.config/nvim/lazy-lock.json

# zsh history and completion cache
configs/zsh/.config/zsh/.zsh_history
configs/zsh/.config/zsh/.zcompdump*

# Local override files (user-specific, not tracked)
*.local

# But do track the stow package for ~/.local/bin
!configs/bin/.local/
!configs/bin/.local/bin/
!configs/bin/.local/bin/dotfiles

# OS
.DS_Store
Thumbs.db

# Dotfiles-managed backup files created during migrations/tests
*.pre-dotfiles-backup
