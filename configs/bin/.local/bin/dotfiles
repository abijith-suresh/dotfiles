#!/usr/bin/env bash
# dotfiles CLI — menu-driven management for your dotfiles

set -euo pipefail

SELF="$(readlink -f "$0")"
DOTFILES_DIR="$(cd "$(dirname "$SELF")/../../../.." && pwd)"
INSTALL_DIR="$DOTFILES_DIR/install"
UNINSTALL_DIR="$INSTALL_DIR/tools/uninstall"

# shellcheck disable=SC1091
source "$INSTALL_DIR/lib/os.sh"
# shellcheck disable=SC1091
source "$INSTALL_DIR/lib/ui.sh"
# shellcheck disable=SC1091
source "$INSTALL_DIR/lib/stow.sh"

UNINSTALL_TOOLS=(
  alacritty
  bash
  bat
  btop
  fastfetch
  fzf
  git
  lazydocker
  lazygit
  neovim
  ripgrep
  starship
  tmux
  vim
  zellij
  zsh
)

# ── Header ────────────────────────────────────────────────────────────────────

show_header() {
  ui_header

  local platform date_str
  platform="$(detect_os)"
  date_str="$(date '+%b %Y')"

  printf '%s     %s · catppuccin mocha · %s%s\n\n' \
    "$_UI_MUTED" "$platform" "$date_str" "$_UI_RST"
}

# ── Profile runner ────────────────────────────────────────────────────────────

run_profile() {
  local profile="$1"
  case "$profile" in
    wsl) bash "$INSTALL_DIR/profiles/wsl.sh" ;;
    linux) bash "$INSTALL_DIR/profiles/linux.sh" ;;
    auto) run_profile "$(detect_os)" ;;
    *)
      ui_error "Unsupported install profile: $profile"
      return 1
      ;;
  esac
}

# ── Tool metadata ─────────────────────────────────────────────────────────────

tool_label() {
  case "$1" in
    alacritty) echo "Alacritty" ;;
    bash) echo "Bash" ;;
    bat) echo "bat" ;;
    btop) echo "btop" ;;
    fastfetch) echo "fastfetch" ;;
    fzf) echo "fzf" ;;
    git) echo "Git" ;;
    lazydocker) echo "lazydocker" ;;
    lazygit) echo "lazygit" ;;
    neovim) echo "Neovim" ;;
    ripgrep) echo "ripgrep" ;;
    starship) echo "Starship" ;;
    tmux) echo "tmux" ;;
    vim) echo "Vim" ;;
    zellij) echo "Zellij" ;;
    zsh) echo "zsh" ;;
    *) echo "$1" ;;
  esac
}

normalize_uninstall_tool() {
  case "$1" in
    alacritty) echo "alacritty" ;;
    bash) echo "bash" ;;
    bat) echo "bat" ;;
    btop) echo "btop" ;;
    fastfetch) echo "fastfetch" ;;
    fzf) echo "fzf" ;;
    git) echo "git" ;;
    lazydocker) echo "lazydocker" ;;
    lazygit) echo "lazygit" ;;
    nvim|neovim) echo "neovim" ;;
    rg|ripgrep) echo "ripgrep" ;;
    starship) echo "starship" ;;
    tmux) echo "tmux" ;;
    vim) echo "vim" ;;
    zellij) echo "zellij" ;;
    zsh) echo "zsh" ;;
    *) return 1 ;;
  esac
}

tool_package() {
  case "$1" in
    alacritty) echo "alacritty" ;;
    bash) echo "bash" ;;
    bat) echo "bat" ;;
    btop) echo "btop" ;;
    fastfetch) echo "fastfetch" ;;
    fzf) echo "fzf" ;;
    git) echo "git" ;;
    lazydocker) echo "lazydocker" ;;
    lazygit) echo "lazygit" ;;
    neovim) echo "nvim" ;;
    ripgrep) echo "ripgrep" ;;
    starship) echo "starship" ;;
    tmux) echo "tmux" ;;
    vim) echo "vim" ;;
    zellij) echo "zellij" ;;
    zsh) echo "zsh" ;;
    *) echo "" ;;
  esac
}

tool_bin() {
  case "$1" in
    fzf) echo "fzf" ;;
    lazydocker) echo "lazydocker" ;;
    lazygit) echo "lazygit" ;;
    starship) echo "starship" ;;
    zellij) echo "zellij" ;;
    *) echo "" ;;
  esac
}

tool_extra_paths() {
  case "$1" in
    tmux) printf '%s\n' "$HOME/.tmux/plugins" ;;
    vim) printf '%s\n' "$HOME/.vim/pack/vendor/start/catppuccin" ;;
    zsh) printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git" ;;
  esac
}

tool_uninstall_script() {
  echo "$UNINSTALL_DIR/uninstall-$1.sh"
}

package_has_targets() {
  local package="$1"
  local package_dir target source rel_path

  [ -z "$package" ] && return 1
  package_dir="$DOTFILES_DIR/configs/$package"
  [ -d "$package_dir" ] || return 1

  while IFS= read -r -d '' rel_path; do
    rel_path="${rel_path#./}"
    source="$package_dir/$rel_path"
    target="$HOME/$rel_path"

    if path_matches_source "$target" "$source"; then
      return 0
    fi
  done < <(package_entries "$package_dir")

  return 1
}

tool_has_removable_state() {
  local tool="$1"
  local package binary path

  package="$(tool_package "$tool")"
  binary="$(tool_bin "$tool")"

  if package_has_targets "$package"; then
    return 0
  fi

  if [ -n "$binary" ] && { [ -e "$HOME/.local/bin/$binary" ] || [ -L "$HOME/.local/bin/$binary" ]; }; then
    return 0
  fi

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    if [ -e "$path" ] || [ -L "$path" ]; then
      return 0
    fi
  done < <(tool_extra_paths "$tool")

  return 1
}

tool_plan() {
  local tool="$1"
  local package binary
  local parts=()
  local path

  package="$(tool_package "$tool")"
  binary="$(tool_bin "$tool")"

  if [ -n "$package" ]; then
    parts+=("stow:$package")
  fi

  if [ -n "$binary" ]; then
    parts+=("bin:~/.local/bin/$binary")
  fi

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    parts+=("path:${path/#$HOME/~}")
  done < <(tool_extra_paths "$tool")

  if [ "${#parts[@]}" -eq 0 ]; then
    echo "safe uninstall"
    return
  fi

  local joined="${parts[0]}"
  local i
  for ((i = 1; i < ${#parts[@]}; i++)); do
    joined+=" · ${parts[$i]}"
  done
  echo "$joined"
}

show_uninstall_plan() {
  ui_section "Uninstall: $(tool_label "$1")"
  ui_info "This safe uninstall removes repo-managed config and local add-ons only."
  ui_info "Will remove: $(tool_plan "$1")"
}

run_uninstall_tool() {
  local tool="$1"
  local script

  script="$(tool_uninstall_script "$tool")"
  if [ ! -f "$script" ]; then
    ui_error "Missing uninstall script: $script"
    return 1
  fi

  show_uninstall_plan "$tool"
  if ! ui_confirm "Continue uninstalling $(tool_label "$tool")?"; then
    ui_warn "Cancelled uninstall"
    return 0
  fi

  bash "$script"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_clean_backups() {
  bash "$DOTFILES_DIR/scripts/clean-backups.sh" "$@"
}

cmd_update() {
  ui_section "System Update"

  export DOTFILES_SPINNER=pulse
  if grep -qi microsoft /proc/version 2>/dev/null; then
    if command -v gum >/dev/null 2>&1; then
      gum spin --spinner pulse --title "Upgrading system packages..." --show-error -- \
        bash -c 'sudo apt update -qq && sudo apt upgrade -y && sudo apt autoremove -y'
    else
      sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y
    fi
    ui_ok "system packages"
  elif [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "$ID" in
      ubuntu|debian)
        if command -v gum >/dev/null 2>&1; then
          gum spin --spinner pulse --title "Upgrading apt packages..." --show-error -- \
            bash -c 'sudo apt update -qq && sudo apt upgrade -y && sudo apt autoremove -y'
        else
          sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y
        fi
        ui_ok "system packages"
        ;;
      arch)
        if command -v gum >/dev/null 2>&1; then
          gum spin --spinner pulse --title "Upgrading pacman packages..." --show-error -- \
            sudo pacman -Syu --noconfirm
        else
          sudo pacman -Syu --noconfirm
        fi
        ui_ok "system packages"
        ;;
      fedora)
        if command -v gum >/dev/null 2>&1; then
          gum spin --spinner pulse --title "Upgrading dnf packages..." --show-error -- \
            sudo dnf upgrade -y
        else
          sudo dnf upgrade -y
        fi
        ui_ok "system packages"
        ;;
    esac
  fi

  if command -v zsh >/dev/null 2>&1 && [ -f "$HOME/.config/zsh/.zshrc" ] && \
     grep -q zinit "$HOME/.config/zsh/.zshrc" 2>/dev/null; then
    if command -v gum >/dev/null 2>&1; then
      gum spin --spinner pulse --title "Updating zinit plugins..." --show-error -- \
        zsh -i -c "zinit self-update; zinit update --all" 2>/dev/null || true
    else
      zsh -i -c "zinit self-update; zinit update --all" 2>/dev/null || true
    fi
    ui_ok "zinit plugins"
  fi

  if command -v mise >/dev/null 2>&1; then
    if command -v gum >/dev/null 2>&1; then
      gum spin --spinner pulse --title "Updating mise tools..." --show-error -- \
        mise up 2>/dev/null || true
    else
      mise up 2>/dev/null || true
    fi
    ui_ok "mise tools"
  fi

  if [ -d "$HOME/.tmux/plugins/tpm" ]; then
    if command -v gum >/dev/null 2>&1; then
      gum spin --spinner pulse --title "Updating tmux plugins..." --show-error -- \
        bash -c 'TMUX_PLUGIN_MANAGER_PATH="$HOME/.tmux/plugins" \
          "$HOME/.tmux/plugins/tpm/bin/update_plugins" all' 2>/dev/null || true
    else
      TMUX_PLUGIN_MANAGER_PATH="$HOME/.tmux/plugins" \
        "$HOME/.tmux/plugins/tpm/bin/update_plugins" all 2>/dev/null || true
    fi
    ui_ok "tmux plugins"
  fi

  export DOTFILES_SPINNER=moon
  ui_banner_success "Update complete" "system · zinit · mise · tmux"
}

cmd_install_base_setup() {
  bash "$INSTALL_DIR/categories/base-setup.sh"
}

cmd_install_terminal_tools() {
  bash "$INSTALL_DIR/categories/terminal-tools.sh"
}

cmd_install_coding_agents() {
  bash "$INSTALL_DIR/categories/coding-agents.sh"
}

cmd_install_everything() {
  run_profile auto
}

cmd_install() {
  if [ "${1:-}" = "--profile" ]; then
    run_profile "${2:-auto}"
    return
  fi

  case "${1:-}" in
    base|base-setup) cmd_install_base_setup; return ;;
    terminal|terminal-tools) cmd_install_terminal_tools; return ;;
    languages) bash "$INSTALL_DIR/languages/select.sh" "${@:2}"; return ;;
    agents|coding-agents) cmd_install_coding_agents; return ;;
    everything|all) cmd_install_everything; return ;;
    clean-backups) cmd_clean_backups; return ;;
  esac

  if ! command -v gum >/dev/null 2>&1; then
    printf 'gum is required for interactive install menus.\nRun ./install.sh first.\n'
    exit 1
  fi

  local choice
  choice=$(gum choose \
    "Base Setup       · shell, git, bat, eza, zsh, starship" \
    "Terminal Tools   · neovim, tmux, zellij, fzf, lazygit…" \
    "Languages        · node, bun, go, rust, python, java…" \
    "Coding Agents    · pi, claude, codex, gemini, copilot" \
    "Clean Backups    · remove stale stow backup files" \
    "Install Everything · run all categories at once" \
    "Quit" \
    --header "  Install / Setup")

  case "$choice" in
    Base\ Setup*) cmd_install_base_setup ;;
    Terminal\ Tools*) cmd_install_terminal_tools ;;
    Languages*) bash "$INSTALL_DIR/languages/select.sh" ;;
    Coding\ Agents*) cmd_install_coding_agents ;;
    Clean\ Backups*) cmd_clean_backups ;;
    Install\ Everything*) cmd_install_everything ;;
    *) return 0 ;;
  esac
}

cmd_uninstall() {
  local tool selected choice

  if [ -n "${1:-}" ]; then
    tool="$(normalize_uninstall_tool "$1")" || {
      ui_error "Unknown tool: $1"
      ui_info "Available: ${UNINSTALL_TOOLS[*]}"
      exit 1
    }
    run_uninstall_tool "$tool"
    return
  fi

  if ! command -v gum >/dev/null 2>&1; then
    printf 'gum is required for interactive uninstall menus.\nRun ./install.sh first.\n'
    exit 1
  fi

  selected=()
  for tool in "${UNINSTALL_TOOLS[@]}"; do
    if tool_has_removable_state "$tool"; then
      selected+=("$(tool_label "$tool") · $(tool_plan "$tool")")
    fi
  done

  if [ "${#selected[@]}" -eq 0 ]; then
    for tool in "${UNINSTALL_TOOLS[@]}"; do
      selected+=("$(tool_label "$tool") · $(tool_plan "$tool")")
    done
  fi

  choice=$(gum choose "${selected[@]}" --header "  Select a tool to uninstall")
  [ -z "$choice" ] && return 0

  tool="$(normalize_uninstall_tool "$(printf '%s' "$choice" | cut -d'·' -f1 | xargs | tr '[:upper:]' '[:lower:]' | tr ' ' '-')")" || {
    ui_error "Could not parse selection: $choice"
    return 1
  }

  run_uninstall_tool "$tool"
}

# ── Main menu ─────────────────────────────────────────────────────────────────

show_menu() {
  if ! command -v gum >/dev/null 2>&1; then
    printf 'gum is required for interactive menus. Run ./install.sh first.\n'
    exit 1
  fi

  local choice
  choice=$(gum choose \
    "Update           · upgrade system + all managed tools" \
    "Install          · set up tools, agents & languages" \
    "Uninstall        · remove managed config and local add-ons" \
    "Clean Backups    · remove stale stow backup files" \
    "Quit" \
    --header "  What would you like to do?")

  case "$choice" in
    Update*) cmd_update ;;
    Install*) cmd_install ;;
    Uninstall*) cmd_uninstall ;;
    Clean\ Backups*) cmd_clean_backups ;;
    *) return 0 ;;
  esac
}

# ── Entrypoint ────────────────────────────────────────────────────────────────

case "${1:-}" in
  "")
    show_header
    show_menu
    ;;
  update)
    cmd_update
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  uninstall)
    shift
    cmd_uninstall "$@"
    ;;
  clean-backups)
    shift
    cmd_clean_backups "$@"
    ;;
  *)
    printf 'Usage: dotfiles [update|install|uninstall|clean-backups]\n' >&2
    exit 1
    ;;
esac
