#!/usr/bin/env bash
# dotfiles CLI — menu-driven management for your dotfiles

set -euo pipefail

SELF="$(readlink -f "$0")"
DOTFILES_DIR="$(cd "$(dirname "$SELF")/../../../.." && pwd)"
INSTALL_DIR="$DOTFILES_DIR/install"

# shellcheck disable=SC1091
source "$INSTALL_DIR/lib/os.sh"
# shellcheck disable=SC1091
source "$INSTALL_DIR/lib/ui.sh"

show_header() {
  ui_header
}

run_profile() {
  local profile="$1"

  case "$profile" in
    wsl) bash "$INSTALL_DIR/profiles/wsl.sh" ;;
    linux) bash "$INSTALL_DIR/profiles/linux.sh" ;;
    auto) run_profile "$(detect_os)" ;;
    *)
      echo "Unsupported install profile: $profile"
      return 1
      ;;
  esac
}

cmd_theme() {
  bash "$DOTFILES_DIR/scripts/theme.sh" "$@"
}

cmd_update() {
  echo "Starting update..."

  if grep -qi microsoft /proc/version 2>/dev/null; then
    sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y
  elif [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "$ID" in
      ubuntu|debian) sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y ;;
      arch) sudo pacman -Syu --noconfirm ;;
      fedora) sudo dnf upgrade -y ;;
    esac
  fi

  if command -v zsh >/dev/null 2>&1 && [ -f "$HOME/.config/zsh/.zshrc" ] && grep -q zinit "$HOME/.config/zsh/.zshrc"; then
    zsh -i -c "zinit self-update; zinit update --all" 2>/dev/null || true
    echo "  ✓ zinit plugins"
  fi

  if command -v mise >/dev/null 2>&1; then
    mise up 2>/dev/null || true
    echo "  ✓ mise tools"
  fi

  if [ -d "$HOME/.tmux/plugins/tpm" ]; then
    "$HOME/.tmux/plugins/tpm/bin/install_plugins" 2>/dev/null || true
    "$HOME/.tmux/plugins/tpm/bin/update_plugins" all 2>/dev/null || true
    echo "  ✓ tmux plugins"
  fi

  echo "Update complete."
}

install_agents_menu() {
  if ! command -v gum >/dev/null 2>&1; then
    bash "$INSTALL_DIR/agents/all.sh"
    return
  fi

  local choice
  choice=$(gum choose \
    "All" \
    "pi" \
    "claude" \
    "codex" \
    "gemini" \
    "copilot" \
    "opencode" \
    "<< Back" \
    --header "Install coding agents")

  case "$choice" in
    All) bash "$INSTALL_DIR/agents/all.sh" ;;
    pi|claude|codex|gemini|copilot|opencode) bash "$INSTALL_DIR/agents/app-${choice}.sh" ;;
    *) return 0 ;;
  esac
}

cmd_install() {
  if [ "${1:-}" = "--profile" ]; then
    run_profile "${2:-auto}"
    return
  fi

  if ! command -v gum >/dev/null 2>&1; then
    echo "gum is required for interactive install menus."
    echo "Run ./install.sh first."
    exit 1
  fi

  local choice
  choice=$(gum choose \
    "Full Setup" \
    "Languages" \
    "Coding Agents" \
    "Theme" \
    "Quit" \
    --header "Install / setup")

  case "$choice" in
    "Full Setup") run_profile auto ;;
    "Languages") bash "$INSTALL_DIR/languages/select.sh" ;;
    "Coding Agents") install_agents_menu ;;
    "Theme") cmd_theme ;;
    *) return 0 ;;
  esac
}

show_menu() {
  if ! command -v gum >/dev/null 2>&1; then
    echo "gum is required for interactive menus. Run ./install.sh first."
    exit 1
  fi

  local choice
  choice=$(gum choose "Theme" "Update" "Install" "Quit" --header "What would you like to do?")

  case "$choice" in
    Theme) cmd_theme ;;
    Update) cmd_update ;;
    Install) cmd_install ;;
    *) return 0 ;;
  esac
}

case "${1:-}" in
  "")
    show_header
    show_menu
    ;;
  theme)
    shift
    cmd_theme "$@"
    ;;
  update)
    cmd_update
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  *)
    echo "Usage: dotfiles [theme|update|install]"
    exit 1
    ;;
esac
