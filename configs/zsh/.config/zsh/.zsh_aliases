# ~/.config/zsh/.zsh_aliases
# ============================
# Minimal alias set — use lazygit for anything complex
# ============================

# --- File Listing (eza) ---
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza -lh --icons --git --group-directories-first'
  alias la='eza -lah --icons --git --group-directories-first'
  alias lt='eza --tree --icons --level=2 --long --git'
else
  alias ll='ls -lh'
  alias la='ls -lah'
fi

# --- Replacements ---
command -v bat >/dev/null 2>&1 && alias cat='bat'
alias mkdir='mkdir -pv'
command -v zoxide >/dev/null 2>&1 && alias cd='z'
alias grep='grep --color=auto'

# --- Navigation ---
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# --- Shortcuts ---
alias c='clear'
alias please='sudo'
alias :q='exit'

# --- Git (faster than opening lazygit for these) ---
alias g='git'
alias gs='git status -sb'
alias ga='git add -p'
alias glo='git log --oneline --graph'
alias grt='cd "$(git rev-parse --show-toplevel)"'
alias gcm='git commit -m'
alias gcam='git commit -a -m'
alias gcad='git commit -a --amend'
alias grh1='git reset HEAD~1'
alias gp='git push'
alias gl='git pull'

# --- Tools ---
command -v lazygit >/dev/null 2>&1 && alias lzg='lazygit'
command -v lazydocker >/dev/null 2>&1 && alias lzd='lazydocker'
# n is defined as a function in .zsh_functions

# --- Utilities ---
alias path='echo -e ${PATH//:/\\n}'

# --- Global aliases (zsh only) ---
alias -g G='| grep'
alias -g H='| head -30'
alias -g T='| tail -30'
alias -g L='| wc -l'
